{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git restore:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(python3 -m http.server:*)",
      "Bash(npx live-server:*)",
      "Bash(graphify export:*)",
      "Bash(graphify benchmark:*)"
    ],
    "deny": [
      "Read(./students/**)"
    ]
  }
}
